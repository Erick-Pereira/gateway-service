{
  "ReverseProxy": {
    "Routes": {
      "ingestion": {
        "ClusterId": "ingestion-cluster",
        "Match": {
          "Path": "/api/ingestion/{**catch-all}"
        }
      },
      "processing": {
        "ClusterId": "processing-cluster",
        "Match": {
          "Path": "/api/processing/{**catch-all}"
        }
      },
      "market-data": {
        "ClusterId": "market-data-cluster",
        "Match": {
          "Path": "/api/market/{**catch-all}"
        }
      },
      "alerts": {
        "ClusterId": "alerts-cluster",
        "Match": {
          "Path": "/api/alerts/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ingestion-cluster": {
        "Destinations": {
          "ingestion": {
            "Address": "http://ingestion-service:8080/"
          }
        }
      },
      "processing-cluster": {
        "Destinations": {
          "processing": {
            "Address": "http://processing-service:8080/"
          }
        }
      },
      "market-data-cluster": {
        "Destinations": {
          "market": {
            "Address": "http://market-data-service:8080/"
          }
        }
      },
      "alerts-cluster": {
        "Destinations": {
          "alerts": {
            "Address": "http://alert-service:8080/"
          }
        }
      }
    }
  }
}