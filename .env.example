# Copie para .env na pasta do API (Simcag.Gateway.Api usa DotNetEnv.Env.Load() no Program.cs).

# ——— Identity (health check + cluster YARP auth: /api/auth/...) ——
SERVICES__IDENTITY__URL=http://localhost:8080
# Alias legado (vai ser removido): IDENTITY_SERVICE_URL

# ——— JWT HS256 (deve coincidir com Identity / JwtTokenService) ——
# Em produção JWT__SECRET é obrigatório; em Development pode faltar (segredo de dev no código).
JWT__SECRET=ChangeThisSecretKey12345678901234567890
JWT__ISSUER=Simcag.IdentityService
JWT__AUDIENCE=Simcag.Clients

# ——— Redis (opcional) — rate limiting e cache usam IDistributedCache.
# Sem variável ou com "memory" / "inmemory" → cache em memória (ver DependencyInjection.cs).
# REDIS__CONNECTION=localhost:6379
# Alternativas legadas: REDIS_CONNECTION, ConnectionStrings__Redis

# ——— Rate limiting — pedidos por cliente por janela de 1 minuto (default 100)
RATE_LIMIT_REQUESTS=100

# ——— Destinos YARP (defaults Docker em YarpConfig; sobrepõe com estes nomes ou GATEWAY_* abaixo)
SERVICES__INGESTION__URL=http://localhost:8081
SERVICES__ALERT__URL=http://localhost:8083
SERVICES__NOTIFICATION__URL=http://localhost:8084
SERVICES__PROCESSING__URL=http://localhost:8082
# Aliases legados (vão ser removidos): INGESTION_SERVICE_URL, ALERT_SERVICE_URL, NOTIFICATION_SERVICE_URL, PROCESSING_SERVICE_URL

# Opcional: endereços explícitos (ClusterAddress em Simcag.Gateway.Infrastructure/Proxy/YarpConfig.cs)
# GATEWAY_IDENTITY_ADDRESS=http://localhost:8080
# GATEWAY_INGESTION_ADDRESS=http://localhost:8081
# GATEWAY_ALERT_ADDRESS=http://localhost:8083
# GATEWAY_NOTIFICATION_ADDRESS=http://localhost:8084
# GATEWAY_PROCESSING_ADDRESS=http://localhost:8082

# Nota: as rotas YARP atuais não incluem AI / Market Data / Price Analysis; acrescente clusters em código se precisar.
