# Gateway — configuração para dev local (fora do Docker).
# Em Docker/produção estas variáveis são definidas no docker-compose ou no ambiente.

# Porta do gateway
ASPNETCORE_URLS=http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development

# JWT (deve coincidir com identity-service)
JWT__SECRET=Simcag.Dev.Jwt.NotForProduction.AlignWithIdentityService.01!
JWT__ISSUER=Simcag.IdentityService
JWT__AUDIENCE=Simcag.Clients

# Endereços dos serviços downstream (dev local = localhost)
SERVICES__IDENTITY__URL=http://localhost:5001
SERVICES__INGESTION__URL=http://localhost:5002
SERVICES__PROCESSING__URL=http://localhost:5003
SERVICES__ALERT__URL=http://localhost:5004
SERVICES__NOTIFICATION__URL=http://localhost:5005
SERVICES__PRICE_ANALYSIS__URL=http://localhost:5006
SERVICES__MARKET_DATA__URL=http://localhost:5007
SERVICES__AI__URL=http://localhost:5008

# Redis (vazio = in-memory cache, sem Redis local)
# REDIS__CONNECTION=localhost:6379
