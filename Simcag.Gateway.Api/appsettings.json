{
  "ReverseProxy": {
    "Routes": {
      "ingestion-route": {
        "ClusterId": "ingestion-cluster",
        "Match": {
          "Path": "/api/ingestion/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/ingestion"
          }
        ]
      },
      "processing-route": {
        "ClusterId": "processing-cluster",
        "Match": {
          "Path": "/api/processing/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/processing"
          }
        ]
      },
      "alerts-route": {
        "ClusterId": "alerts-cluster",
        "Match": {
          "Path": "/api/alerts/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/alerts"
          }
        ]
      },
      "marketdata-route": {
        "ClusterId": "marketdata-cluster",
        "Match": {
          "Path": "/api/marketdata/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/marketdata"
          }
        ]
      },
      "analysis-route": {
        "ClusterId": "analysis-cluster",
        "Match": {
          "Path": "/api/analysis/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/analysis"
          }
        ]
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/api/ai/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/ai"
          }
        ]
      },
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/auth"
          }
        ]
      }
    },
    "Clusters": {
      "ingestion-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8080"
          }
        }
      },
      "processing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8081"
          }
        }
      },
      "alerts-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8083"
          }
        }
      },
      "marketdata-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8082"
          }
        }
      },
      "analysis-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8084"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8086"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8085"
          }
        }
      }
    }
  },
  "RateLimiting": {
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      }
    ],
    "EndpointRules": [
      {
        "Endpoint": "/api/auth/login",
        "Period": "1m",
        "Limit": 10
      }
    ]
  }
}